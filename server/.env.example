# ===========================================
# Deep-Image API Key 配置
# 至少需要配置 DEEPSEEK_API_KEY，其他可选
# ===========================================

# DeepSeek（必填 - 语言分析和视觉识别）
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 豆包 Vision（可选 - 字节跳动火山引擎）
DOUBAO_API_KEY=your-doubao-key-here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=ep-your-endpoint-id
# Kimi Vision（可选 - Moonshot）
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-32k-vision-preview

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
APP_VERSION=0.1.0
